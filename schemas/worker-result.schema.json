{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.dev/schemas/worker-result.schema.json",
  "title": "WorkerResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "status",
    "summary",
    "artifacts"
  ],
  "properties": {
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff",
        "result"
      ],
      "properties": {
        "handoff": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "nextStep": {
      "type": "string"
    },
    "resumeFrom": {
      "type": "string"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
